# Dataset bruto e processado: versionado via DVC, não diretamente no git.
# Não ignoramos `data/` inteiro aqui — os ponteiros `*.dvc` (ex.: data/raw_data.dvc)
# precisam ser rastreados pelo git. O próprio DVC gerencia um `data/.gitignore`
# com os caminhos de dado real que passam a ser rastreados via cache do DVC.

# Storage do remote local do DVC (fica fora do git; dados reais só existem lá e no cache do DVC)
/dvc-storage/

# Documentos PDF (specs, referências etc.)
*.pdf

# Ambiente virtual e cache do Python/uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# MLflow / artefatos locais de treino
mlruns/
mlartifacts/
mlflow.db
# Backend store sqlite + artifact root do serviço `mlflow` do docker-compose
/mlflow-data/

# Configuração local (segredos/valores específicos do ambiente) — apenas .env.example é commitado
.env
.env.*
!.env.example
