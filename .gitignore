# Dataset bruto (data/raw_data/): amostra pequena (ml-latest-small), commitada
# diretamente no git para que qualquer clone já traga os dados. Os artefatos
# gerados pelo pipeline DVC (data/processed_data/, models/) continuam versionados
# só via DVC, não diretamente no git — ver data/processed_data/.gitignore e
# models/.gitignore, gerenciados pelo próprio DVC.

# Storage do remote local do DVC (fica fora do git; artefatos do pipeline só existem lá e no cache do DVC)
/dvc-storage/

# Documentos PDF (specs, referências etc.)
*.pdf

# Ambiente virtual e cache do Python/uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# MLflow / artefatos locais de treino
mlruns/
mlartifacts/
mlflow.db
# Backend store sqlite + artifact root do serviço `mlflow` do docker-compose
/mlflow-data/

# Configuração local (segredos/valores específicos do ambiente) — apenas .env.example é commitado
.env
.env.*
!.env.example
