# Copie este arquivo para `.env` e ajuste os valores conforme necessário.
# Nenhum valor sensível deve ser commitado — apenas este exemplo.

# Semente para reprodutibilidade (split de dados, inicialização de modelo, treino)
SEMENTE_ALEATORIA=42

# URI do servidor de tracking do MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Diretórios de dados e modelos
DIRETORIO_DADOS_BRUTOS=data/raw_data
DIRETORIO_DADOS_PROCESSADOS=data/processed_data
DIRETORIO_MODELOS=models
