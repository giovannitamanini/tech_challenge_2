# Copie este arquivo para `.env` e ajuste os valores conforme necessário.
# Nenhum valor sensível deve ser commitado — apenas este exemplo.

# Semente para reprodutibilidade (split de dados, inicialização de modelo, treino)
SEMENTE_ALEATORIA=42

# URI do servidor de tracking do MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Diretórios de dados e modelos
DIRETORIO_DADOS_BRUTOS=data/raw_data
DIRETORIO_DADOS_PROCESSADOS=data/processed_data
DIRETORIO_MODELOS=models

# Usado só pelo serviço `api` do docker-compose.yml (Docker-fora-do-Docker: o container da
# API dispara o container `train` como irmão via socket do Docker do host, POST /treino).
# NÃO é lido pelo código Python (não passa por Configuracoes) — é uma variável de
# substituição do próprio `docker compose`, exigida para os volumes relativos do `train`
# (ex.: `./data`) resolverem contra o caminho de verdade do host quando o `docker compose
# run` é disparado de dentro do container da API, não do host diretamente.
# Em Linux nativo: o caminho absoluto normal do projeto (ex.: /home/usuario/tech_challenge_2).
# No Docker Desktop (Windows/Mac): pode exigir o caminho traduzido que o daemon reconhece
# internamente (varia por versão/backend) — se `POST /treino` disparar o `train` com volumes
# vazios/errados, rode `docker compose run --rm train pwd` e ajuste este valor até bater.
HOST_PROJECT_DIR=/caminho/absoluto/para/tech_challenge_2
